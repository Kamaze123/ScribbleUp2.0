<%- include("partials/header.ejs") %>

<main class="container">
    <form action="/submit" method="post" class="post-form">
        <h2>Create your own blog</h2>

        <label for="title">Title</label>
        <input type="text" id="title" name="title" placeholder="Enter title of your blog" required>

        <label for="content">Content</label>
        <textarea name="content" id="content" placeholder="Enter content" required></textarea>

        <button type="submit">Publish</button>
    </form>
</main>

<%- include("partials/footer.ejs") %>