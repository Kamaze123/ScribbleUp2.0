<%- include("partials/header.ejs") %>

<main class="container blog-page">

  <article class="blog-full">

    <h1 class="blog-full-title">
      <%= title %>
    </h1>

    <p class="blog-full-date">
      <%= new Date(created).toDateString() %>
    </p>

    <div class="blog-full-content">
      <%- content.replace(/\n/g, "<br>") %>
    </div>

    <div class="blog-full-actions">
      <a href="/" class="back-link">← Back to blogs</a>
    

    <% if (user && (user.role === 'admin' || user.role === 'editor' || user.id === blogUserId)) { %>
        <a href="/blog/<%= blogId %>/edit" class="edit-btn">Edit</a>
        <form method="POST" action="/blog/<%= blogId %>?_method=DELETE" style="display:inline">
          <button type="submit" class="delete-btn" 
            onclick="return confirm('Delete this blog permanently?')">Delete</button>
        </form>
      <% } %>

      </div>

  </article>

</main>

<%- include("partials/footer.ejs") %>
